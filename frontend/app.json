{
  "expo": {
    "name": "CampuStay",
    "slug": "campustay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/campuStayLogo.png",
    "scheme": "campustay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.github.giwrgoskyriakos.CampuStay"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/campuStayLogoTransparent.png",
        "backgroundColor": "#07404C"
      },
      "edgeToEdgeEnabled": true,
      "package": "CampuStay.Android",
      "googleServicesFile": "./google-services.json",
      "navigationBar": {
        "backgroundColor": "#00000000",
        "barStyle": "light-content"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/campuStayLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload photos to complete your roommate profile"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/campuStayLogoTransparent.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#07404C"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ad8bcd67-fd40-4feb-b462-28498892be45"
      }
    },
    "owner": "gkyriakos92"
  }
}
